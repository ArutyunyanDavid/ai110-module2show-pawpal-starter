classDiagram
    %% PawPal+ Phase 1 draft UML.
    %% Owner has many Pets, Pet has many Tasks, Scheduler uses all three to build a daily plan.

    class Owner {
        +str name
        +int minutes_available
        +list~str~ preferences
        +list~Pet~ pets
        +add_pet(pet) None
        +total_tasks() int
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task) None
        +edit_task(index, task) None
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +priority_rank() int
    }

    class Scheduler {
        +Owner owner
        +generate_plan() list~Task~
        +explain_plan(plan) str
    }

    Owner "1" --> "*" Pet : has many
    Pet "1" --> "*" Task : has many
    Scheduler ..> Owner : uses
    Scheduler ..> Pet : uses
    Scheduler ..> Task : uses
